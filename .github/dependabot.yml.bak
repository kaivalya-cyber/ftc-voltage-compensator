# Dependabot config \u2014 weekly bumps of GitHub Actions only.
#
# The Gradle wrapper distribution itself (gradle-wrapper.properties) is
# NOT covered by Dependabot's `gradle` ecosystem; bump it manually with
# `gradle wrapper --gradle-version=X.Y.Z && shasum -a 256
# gradle/wrapper/gradle-wrapper.properties`.
#
# Likewise the `gradle` ecosystem only tracks declared dependencies in
# build.gradle / settings.gradle, which this repo has none of.  We
# intentionally keep this file minimal.
version: 2
updates:
  - package-ecosystem: "github-actions"
    directory: "/"
    schedule:
      interval: "weekly"
      day: "monday"
